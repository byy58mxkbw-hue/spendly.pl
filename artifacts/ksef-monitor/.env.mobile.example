# Konfiguracja buildu MOBILNEGO (Capacitor). Skopiuj do .env.mobile i uzupełnij.
# .env.mobile jest w .gitignore — nie commituj prawdziwych wartości.
#
# W appce natywnej nie ma reverse-proxy ani domeny frontu, więc WSZYSTKIE
# adresy muszą być absolutne (wskazywać prod API na Railway).

# Adres api-server na Railway (bez /api na końcu).
VITE_API_BASE_URL=https://api-server-production-de7e.up.railway.app

# Klerk publishable key (pk_live_...) — skopiuj z Railway (serwis frontendu,
# zmienna VITE_CLERK_PUBLISHABLE_KEY) albo z panelu Clerk.
# W natywnym WebView hostname to "localhost", więc automatyczne wykrywanie
# klucza z domeny NIE działa — ta zmienna jest obowiązkowa.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Proxy Clerk przez api-server (produkcja).
VITE_CLERK_PROXY_URL=https://api-server-production-de7e.up.railway.app/api/__clerk
