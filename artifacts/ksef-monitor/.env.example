# Copy to .env (or .env.local) and fill in real values. Never commit the real file.

# Base URL of the api-server. Use "/api" if the frontend and API share one
# domain behind a reverse proxy — then no value (and no CORS) is needed at all.
VITE_API_BASE_URL=https://api.twojadomena.pl

# Clerk publishable key (safe to expose client-side — use pk_live_ in production).
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Optional — only needed if Clerk is proxied through a custom path/domain.
VITE_CLERK_PROXY_URL=

# Optional — Sentry error monitoring (frontend). Unset = wyłączone (no-op).
VITE_SENTRY_DSN=
