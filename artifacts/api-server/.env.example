# Copy to .env and fill in real values. Never commit the real .env file.

# Postgres connection string (lib/db/src/index.ts requires this to be set)
DATABASE_URL=postgresql://user:password@localhost:5432/spendly_db

# AES-256-GCM key used to encrypt KSeF tokens before they're stored.
# Use a long, random value in production — do NOT reuse the dev placeholder.
KSEF_ENCRYPTION_KEY=

# Clerk auth (use pk_live_/sk_live_ in production, not pk_test_/sk_test_)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NODE_ENV=production
PORT=8080

# Comma-separated list of allowed CORS origins for the production frontend,
# e.g. https://app.twojadomena.pl. Local dev origins are always allowed
# regardless of this value (see artifacts/api-server/src/app.ts).
ALLOWED_ORIGIN=

# Optional — comma-separated Clerk user IDs granted access to the admin panel.
ADMIN_USER_IDS=

# Optional — pino log level (default: info).
LOG_LEVEL=info

# Optional — one-time migration: claims legacy ("__legacy__") owned rows for
# the Clerk account matching this email on first login. Leave unset once done.
LEGACY_OWNER_EMAIL=

# Optional — enables AI product categorization / AI CFO features. Without it,
# categorization falls back to keyword matching.
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Optional — Sentry error monitoring (backend). Unset = wyłączone (no-op).
SENTRY_DSN=

# Optional — kolejka zadań pg-boss (PoC). "true" = włącz (tworzy schemat `pgboss`
# w tej samej bazie DATABASE_URL i przenosi sprawdzanie alertów na kolejkę z retry).
# Domyślnie wyłączona — zachowanie inline jak dotąd.
PGBOSS_ENABLED=false
